from typing import Dict, Optional, List
import pandas as pd
from strategy_expert.base_strategy import BaseStrategy, StrategyOutput
from strategy_expert.strategy_config import get_pipeline_config


class YourStrategyNameStrategy(BaseStrategy):
    """
    [Strategy Name] - [One-line description]
    
    This strategy looks for:
    - Condition 1: [Description]
    - Condition 2: [Description]
    - Condition 3: [Description]
    """
    
    def __init__(self):
        super().__init__()
        self.name = "Your Strategy Name"  # ← CHANGE THIS
        self.description = "Brief description of what this strategy does"
        
        # ===== LOAD CONFIGURATION =====
        pipeline_config = get_pipeline_config()
        
        # ===== SET YOUR THRESHOLDS =====
        # You can load from config or set defaults
        self.condition_threshold_1 = 0.5
        self.condition_threshold_2 = 1.5
        self.buy_confidence = 0.85
        self.sell_confidence = 0.85
        
        # ===== PATTERN LISTS (if needed) =====
        self.bullish_patterns = [
            'hammer', 'bullish_engulfing', 'morning_star', 'piercing_pattern',
            'double_bottom', 'inverse_head_and_shoulders', 'ascending_triangle'
        ]
        
        self.bearish_patterns = [
            'shooting_star', 'bearish_engulfing', 'evening_star', 'dark_cloud_cover',
            'double_top', 'head_and_shoulders', 'descending_triangle'
        ]

    def generate_signal(self, df: pd.DataFrame, indicators: Dict,
                       market_regime: Dict, module_signals: Dict = None) -> Optional[StrategyOutput]:
        """
        Generate trading signal
        
        Args:
            df: OHLCV DataFrame (raw price data)
            indicators: Technical indicators (RSI, MACD, ADX, ATR, etc.)
            market_regime: Market regime data (regime, bias, trend_strength)
            module_signals: Optional signals from other modules (for reference)
        
        Returns:
            StrategyOutput with full trade setup, or None if no signal
        """
        
        # ===== 1. EXTRACT REQUIRED VALUES =====
        current_price = indicators.get('price', 0)
        if current_price == 0:
            return None
        
        # ===== 2. GET REGIME CONTEXT (for adjustments) =====
        regime = market_regime.get('regime', 'UNKNOWN')
        regime_bias = market_regime.get('bias_score', 0)
        
        # ===== 3. EXTRACT INDICATOR VALUES =====
        rsi = indicators.get('rsi', 50)
        macd_hist = indicators.get('macd_histogram', 0)
        adx = indicators.get('adx', 20)
        atr = indicators.get('atr', current_price * 0.01)
        volume_ratio = indicators.get('volume_ratio', 1.0)
        
        # Additional indicators as needed
        # ema_8 = indicators.get('ema_8', current_price)
        # ema_21 = indicators.get('ema_21', current_price)
        # bb_upper = indicators.get('bb_upper', 0)
        # bb_lower = indicators.get('bb_lower', 0)
        
        # ===== 4. EXTRACT PATTERNS (if available) =====
        pattern_keys = {}
        if module_signals and 'patterns' in module_signals:
            for name, conf in module_signals['patterns'].items():
                key = name.lower().replace(' ', '_')
                pattern_keys[key] = conf
        
        # ===== 5. EXTRACT SMART MONEY DATA (if available) =====
        # bos = indicators.get('bos', False)
        # choch = indicators.get('choch', False)
        # cum_buy_delta = indicators.get('cum_buy_delta', 0)
        # cum_sell_delta = indicators.get('cum_sell_delta', 0)
        
        # ===== 6. BULLISH CONDITIONS =====
        # Define your bullish conditions here
        bullish_score = 0
        bullish_reasons = []
        
        # Condition 1: [Description]
        if rsi > 55:
            bullish_score += 2
            bullish_reasons.append(f"RSI bullish: {rsi:.1f}")
        
        # Condition 2: [Description]
        if macd_hist > 0:
            bullish_score += 2
            bullish_reasons.append("MACD histogram positive")
        
        # Condition 3: [Description]
        if adx > 25:
            bullish_score += 1
            bullish_reasons.append(f"Trend strength: ADX {adx:.1f}")
        
        # Condition 4: Volume confirmation
        if volume_ratio > 1.5:
            bullish_score += 2
            bullish_reasons.append(f"Volume spike: {volume_ratio:.1f}x")
        
        # ===== 7. BEARISH CONDITIONS =====
        bearish_score = 0
        bearish_reasons = []
        
        # Condition 1: [Description]
        if rsi < 45:
            bearish_score += 2
            bearish_reasons.append(f"RSI bearish: {rsi:.1f}")
        
        # Condition 2: [Description]
        if macd_hist < 0:
            bearish_score += 2
            bearish_reasons.append("MACD histogram negative")
        
        # Condition 3: [Description]
        if adx > 25:
            bearish_score += 1
            bearish_reasons.append(f"Trend strength: ADX {adx:.1f}")
        
        # Condition 4: Volume confirmation
        if volume_ratio > 1.5:
            bearish_score += 2
            bearish_reasons.append(f"Volume spike: {volume_ratio:.1f}x")
        
        # ===== 8. DETERMINE ACTION =====
        action = "HOLD"
        confidence = 0.5
        reasons = []
        
        # Minimum score threshold (adjust as needed)
        min_score = 4
        
        if bullish_score >= min_score and bullish_score > bearish_score:
            action = "BUY"
            # Confidence based on score (max 0.95)
            confidence = min(0.95, 0.5 + (bullish_score / 20))
            reasons = bullish_reasons[:4]  # Top 4 reasons
        
        elif bearish_score >= min_score and bearish_score > bullish_score:
            action = "SELL"
            confidence = min(0.93, 0.5 + (bearish_score / 20))
            reasons = bearish_reasons[:4]
        
        # ===== 9. PATTERN CONFIRMATION =====
        if action == "BUY":
            for pattern in self.bullish_patterns:
                if pattern in pattern_keys:
                    reasons.append(f"{pattern.replace('_', ' ').title()} pattern")
                    confidence = min(0.95, confidence + 0.02)
                    break
        elif action == "SELL":
            for pattern in self.bearish_patterns:
                if pattern in pattern_keys:
                    reasons.append(f"{pattern.replace('_', ' ').title()} pattern")
                    confidence = min(0.93, confidence + 0.02)
                    break
        
        # ===== 10. REGIME ADJUSTMENT =====
        if action != "HOLD":
            if action == "BUY" and regime_bias > 0:
                confidence = min(0.95, confidence * 1.05)
                reasons.append(f"Aligned with {regime} regime")
            elif action == "SELL" and regime_bias < 0:
                confidence = min(0.95, confidence * 1.05)
                reasons.append(f"Aligned with {regime} regime")
        
        # ===== 11. CALCULATE ENTRY, SL, TP =====
        if action != "HOLD":
            levels = self.calculate_entry_sl_tp(df, indicators, market_regime, action)
            
            return StrategyOutput(
                action=action,
                confidence=confidence,
                entry=levels['entry'],
                stop_loss=levels['stop_loss'],
                take_profit=levels['take_profit'],
                risk_reward=levels['risk_reward'],
                reasons=reasons[:5],
                strategy_name=self.name,
                indicators_used=['rsi', 'macd', 'adx', 'volume_ratio']  # List what you used
            )
        
        return None

    def calculate_entry_sl_tp(self, df: pd.DataFrame, indicators: Dict,
                              market_regime: Dict, action: str) -> Dict:
        """
        Calculate precise entry, stop loss, and take profit levels
        
        Args:
            df: OHLCV DataFrame
            indicators: Technical indicators
            market_regime: Market regime data
            action: 'BUY' or 'SELL'
        
        Returns:
            Dict with 'entry', 'stop_loss', 'take_profit', 'risk_reward'
        """
        current_price = indicators.get('price', 0)
        atr = indicators.get('atr', 0)
        
        # Fallback ATR if not available
        if atr <= 0:
            atr = current_price * 0.01  # 1% default
        
        if action == 'BUY':
            # ===== BUY SETUP =====
            # Entry: Current price (or adjust based on your strategy)
            entry = current_price
            
            # Stop Loss: Below recent low or based on ATR
            recent_low = indicators.get('recent_low', 0)
            if recent_low > 0:
                stop_loss = min(recent_low * 0.99, entry - (atr * 1.2))
            else:
                stop_loss = entry - (atr * 1.5)
            
            # Take Profit: 2x risk or next resistance
            risk = entry - stop_loss
            take_profit = entry + (risk * 2)
            
            # Optional: Cap at resistance level
            resistance = indicators.get('resistance', 0)
            if resistance > entry:
                take_profit = min(take_profit, resistance)
        
        else:  # SELL
            # ===== SELL SETUP =====
            # Entry: Current price
            entry = current_price
            
            # Stop Loss: Above recent high or based on ATR
            recent_high = indicators.get('recent_high', 0)
            if recent_high > 0:
                stop_loss = max(recent_high * 1.01, entry + (atr * 1.2))
            else:
                stop_loss = entry + (atr * 1.5)
            
            # Take Profit: 2x risk or next support
            risk = stop_loss - entry
            take_profit = entry - (risk * 2)
            
            # Optional: Cap at support level
            support = indicators.get('support', 0)
            if support > 0 and support < entry:
                take_profit = max(take_profit, support)
        
        # Calculate risk/reward
        if action == 'BUY':
            risk = entry - stop_loss
            reward = take_profit - entry
        else:
            risk = stop_loss - entry
            reward = entry - take_profit
        
        risk_reward = reward / risk if risk > 0 else 0
        
        return {
            'entry': entry,
            'stop_loss': stop_loss,
            'take_profit': take_profit,
            'risk_reward': risk_reward
        }